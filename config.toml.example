# makeros native-print hub agent — config (non-secret).
# Installed to /etc/makeros-hub/config.toml.
#
# The per-hub credential is NOT here — it's written 0600 to
# /var/lib/makeros-hub/credential during enrollment, and never logged.

# The makeros cloud base URL this hub reports to (your prod host).
# Outbound HTTPS only — no inbound ports needed on the shop LAN.
cloud_url = "https://your-makeros-host.example"

# Heartbeat cadence in seconds. The cloud can override this per heartbeat
# response (nextPollMs), so you rarely need to change it here.
heartbeat_sec = 30
